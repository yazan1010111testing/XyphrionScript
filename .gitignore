# Xyphrion .gitignore

# User profiles and keys (don't upload personal data)
profiles/key.txt
profiles/*.txt
!profiles/commit.txt
!profiles/gui.txt

# Temporary files
*.tmp
*.log

# System files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Backup files
*.bak
*~
